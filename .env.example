# GCP Infrastructure Environment Configuration
# Copy this to .env.local and update with your values

# ===========================================
# GCP Configuration
# ===========================================
export PROJECT_ID="your-gcp-project-id"
export REGION="us-central1"
export PROJECT_NAME="gcp-iac"

# ===========================================
# GKE Configuration
# ===========================================
export CLUSTER_NAME="gke-primary-cluster"
export CLUSTER_ZONE="us-central1"

# ===========================================
# Terraform Configuration
# ===========================================
export TF_VAR_project_id="your-gcp-project-id"
export TF_VAR_region="us-central1"
export TF_VAR_project_name="gcp-iac"

# Optional: Enable Terraform debug logging
# export TF_LOG=DEBUG
# export TF_LOG_PATH="/tmp/terraform.log"

# ===========================================
# Networking Configuration
# ===========================================
export TF_VAR_vpc_primary_cidr="10.0.0.0/16"
export TF_VAR_gke_nodes_cidr="10.1.0.0/20"
export TF_VAR_pods_cidr="10.64.0.0/14"
export TF_VAR_services_cidr="10.68.0.0/14"

# ===========================================
# GKE Configuration
# ===========================================
export TF_VAR_gke_min_nodes=3
export TF_VAR_gke_max_nodes=10
export TF_VAR_gke_machine_type="n2-standard-4"
export TF_VAR_enable_binary_authorization=true
export TF_VAR_enable_workload_identity=true
export TF_VAR_enable_gke_dataplane_v2=true

# ===========================================
# Database Configuration
# ===========================================
export TF_VAR_postgres_version="POSTGRES_15"
export TF_VAR_postgres_tier="db-f1-micro"
export TF_VAR_postgres_disk_size_gb=10
export TF_VAR_postgres_database_name="application"

export TF_VAR_redis_version="7.0"
export TF_VAR_redis_memory_size_gb=1
export TF_VAR_redis_tier="STANDARD"

# ===========================================
# GitHub Actions / CI/CD
# ===========================================
# Set these in GitHub repository Settings > Secrets
# GCP_PROJECT_ID           - Your GCP project ID
# WIF_PROVIDER            - Workload Identity pool provider
# WIF_SERVICE_ACCOUNT     - Service account email for GHA

# ===========================================
# Local Development
# ===========================================
export KUBECONFIG="$HOME/.kube/config"

# Optional: Custom Taskfile variables
export REGION="us-central1"
export LOCAL_PORT="8888"

# ===========================================
# Logging and Debugging
# ===========================================
# export GCLOUD_DEBUG=true
# export KUBECTL_DEBUG=true
